# Environment Variables for AeroRisk AI

# =====================
# General Configuration
# =====================
ENVIRONMENT=development
LOG_LEVEL=info

# =====================
# Go Engine Configuration
# =====================
ENGINE_PORT=8080
ADMIN_PORT=8081
GRPC_PORT=9090
WS_PORT=8082

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka/Redpanda Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_ORDERS=orders
KAFKA_TOPIC_TRADES=trades
KAFKA_TOPIC_EVENTS=events
KAFKA_TOPIC_RISK_DECISIONS=risk_decisions

# Matching Engine Configuration
MATCHING_ENGINE_WORKERS=4
RING_BUFFER_SIZE=65536
BATCH_SIZE=100

# =====================
# AI Guardrail Configuration
# =====================
AI_SERVICE_PORT=8000
AI_LOG_LEVEL=info

# LLM Configuration
LLM_PROVIDER=local
LLM_MODEL_NAME=mistral-7b-instruct
LLM_BASE_URL=http://localhost:11434
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.0

# RAG Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=compliance_docs
QDRANT_API_KEY=

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aerorisk
POSTGRES_PASSWORD=aerorisk_password
POSTGRES_DB=aerorisk_incidents

# Vector Search Configuration
VECTOR_DIMENSION=768
VECTOR_TOP_K=5

# Risk Scoring Configuration
RISK_THRESHOLD_LOW=0.3
RISK_THRESHOLD_MEDIUM=0.6
RISK_THRESHOLD_HIGH=0.8
CIRCUIT_BREAKER_TIMEOUT_MS=5000
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000

# =====================
# Observability Configuration
# =====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=aerorisk-ai

# =====================
# Security Configuration
# =====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_KEY_HEADER=X-API-Key
RATE_LIMIT_REQUESTS_PER_SECOND=1000

# =====================
# Circuit Breaker Configuration
# =====================
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_SECONDS=30

# =====================
# Sanctions Configuration
# =====================
SANCTIONS_CHECK_ENABLED=true
OFAC_SDN_FILE_PATH=data/seed/sanctions/ofac_sdn_sample.csv

# =====================
# Compliance Configuration
# =====================
COMPLIANCE_RULES_PATH=data/seed/compliance_rules
MIFID2_ENABLED=true
FINRA_ENABLED=true
SOX_ENABLED=true

# =====================
# User Profile Configuration
# =====================
USER_PROFILES_PATH=data/seed/user_profiles/synthetic_profiles.json

# =====================
# Audit Logging Configuration
# =====================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=/var/log/aerorisk/audit
S3_BUCKET_NAME=aerorisk-audit-logs
S3_REGION=us-east-1

# =====================
# Performance Tuning
# =====================
GOMAXPROCS=0
PYTHON_ASYNCIO_LOOP_THREADS=4
KAFKA_CONSUMER_BATCH_SIZE=100
KAFKA_CONSUMER_MAX_POLL_RECORDS=500
